# Enforce LF line endings for all text files across all platforms.
# This prevents the CRLF ↔ LF cycle between Windows Git and Biome/Ultracite.
* text=auto eol=lf

# Ensure these common text files are always normalized to LF
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.jsonc text eol=lf
*.css text eol=lf
*.md text eol=lf
*.mdx text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.html text eol=lf
*.toml text eol=lf
*.rs text eol=lf
*.svg text eol=lf
*.xml text eol=lf

# Binary files — don't touch
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
