{
  "name": "catalyzer",
  "version": "2.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "format:check": "turbo format:check",
    "clean": "turbo run clean",
    "typecheck": "turbo typecheck",
    "shadcn": "pnpm --filter @workspace/ui shadcn",
