{
  "name": "create-catalyzer",
  "version": "0.1.2",
  "description": "Scaffolding CLI for Catalyzer",
  "license": "MIT",
  "author": "odest",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "catalyzer",
    "tauri",
    "nextjs",
    "turborepo",
    "scaffold",
    "create",
    "cli",
    "monorepo",
    "template"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/odest/catalyzer.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/odest/catalyzer/issues"
  },
  "homepage": "https://catalyzer.dev",
  "type": "module",
  "files": [
    "dist",
    "templates"
  ],
  "bin": {
    "catalyzer": "./dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node ./dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo",
    "test": "vitest run"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.5",
    "giget": "^3.2.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.19.42",
    "@workspace/typescript-config": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "~5.9.3",
    "vitest": "^4.1.8"
  }
}
